  id        Int      @id @default(autoincrement())
  value     String?
  veryfied  Int?
  wordId    Int?
  meaningId Int?

  word      Meaning? @relation("EnWord", fields: [wordId], references: [id], onDelete: Cascade)
  meaning   Meaning? @relation("EnMeaning", fields: [meaningId], references: [id], onDelete: Cascade)

  @@map("en")
}

