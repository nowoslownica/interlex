// Карта основ → массив lexemeId омонимов (хеш-таблица для префиксного поиска омонимов)
// base — текстовая основа (уникальный ключ), wordIds — JSON-строка с массивом ID лексем-омонимов
model BaseHomonym {
  id      Int    @id @default(autoincrement())
  base    String @unique // Основа (н-р: "vod" для "voda")
  wordIds String          // JSON-массив: "[1, 5, 12]"

  @@map("base_homonyms")
  @@index([base])
}

// Таблица аномалий флексий
// Хранит нестандартные флексии для конкретных слов
// Значение флексии (н-р: "-ami", "-ov")
// Ключ-склейка граммемы (н-р: "PL_INST", "PL_GEN")
model InflectionAnomaly {
  id         Int    @id @default(autoincrement())
  lexemeId     Int
  inflection String
  grammeme   String

  lexeme       Lexeme   @relation(fields: [lexemeId], references: [id], onDelete: Cascade)

  @@map("inflection_anomalies")
  @@index([lexemeId])
  @@index([grammeme])
}

model ProtoSlavicWord {
  id        Int    @id @default(autoincrement())
  lemma     String
  body      String @default("")
  sourceUrl String @default("") @map("source_url")

  @@map("proto_slavic_words")
  @@index([lemma])
}