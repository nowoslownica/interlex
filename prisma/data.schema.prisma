generator client {
  provider = "prisma-client"
  output   = "./generated/data"
}

datasource db {
  provider = "sqlite"
}

model Word {
  id              Int              @id @default(autoincrement())
  slug            String           @unique
  external_id     Int?
  value           String?
  nsl             String?
  isv             String?
  transcription   String?
  field           String?
  type            String?
  pos             String?
  aspect          String?
  transitivity    String?
  animacy         String?
  degree          String?
  pronType        String?
  numType         String?
  frequency       String?
  intelligibility String?
  addition        String?
  sameInLanguages String?
  etymology       String?

  proto           String?
  paradigm        String?
  protoStemClass  String?
  stemExtension   String?
  genesis         String?

  // ПОЛЯ ДЛЯ АВТОМАТИЧЕСКОЙ ГЕНЕРАЦИИ ПАРАДИГМ
  base            String?
  gender          String?
  declension      Int?
  conjugation     Int?
  accentSyllable  Int?
  alternationType String?
  fleetingVowelAt Int?

  // Маркер аномалий флексий
  hasAnomalies    Boolean          @default(false)

  // Обратные связи Prisma
  meanings        Meaning[]
  roots_words     RootWord[]
  synonymsRoot    Synonym[]        @relation("SynonymRoot")
  synonymsWord    Synonym[]        @relation("SynonymWord")
  antonymsRoot    Antonym[]        @relation("AntonymRoot")
  antonymsWord    Antonym[]        @relation("AntonymWord")
  anomalies       InflectionAnomaly[]

  @@map("words")
  @@index([slug])
}


model Word_text {
  id      Int    @id
  value   String
  rootId  String

  @@ignore
}

model Meaning {
  id       Int       @id @default(autoincrement())
  wordId   Int
  meaning  String?
  examples String?

  // Связь с таблицей слов
  word     Word      @relation(fields: [wordId], references: [id], onDelete: Cascade)

  // Обратные связи для языковых таблиц
  en_word  En[]      @relation("EnWord")
  en_mean  En[]      @relation("EnMeaning")
  ru_word  Ru[]      @relation("RuWord")
  ru_mean  Ru[]      @relation("RuMeaning")
  mk_word  Mk[]      @relation("MkWord")
  mk_mean  Mk[]      @relation("MkMeaning")
  sr_word  Sr[]      @relation("SrWord")
  sr_mean  Sr[]      @relation("SrMeaning")
  uk_word  Uk[]      @relation("UkWord")
  uk_mean  Uk[]      @relation("UkMeaning")
  bg_word  Bg[]      @relation("BgWord")
  bg_mean  Bg[]      @relation("BgMeaning")
  pl_word  Pl[]      @relation("PlWord")
  pl_mean  Pl[]      @relation("PlMeaning")
  be_word  Be[]      @relation("BeWord")
  be_mean  Be[]      @relation("BeMeaning")
  cs_word  Cs[]      @relation("CsWord")
  cs_mean  Cs[]      @relation("CsMeaning")
  sk_word  Sk[]      @relation("SkWord")
  sk_mean  Sk[]      @relation("SkMeaning")
  sl_word  Sl[]      @relation("SlWord")
  sl_mean  Sl[]      @relation("SlMeaning")
  hr_word  Hr[]      @relation("HrWord")
  hr_mean  Hr[]      @relation("HrMeaning")
  cu_word  Cu[]      @relation("CuWord")
  cu_mean  Cu[]      @relation("CuMeaning")
  de_word  De[]      @relation("DeWord")
  de_mean  De[]      @relation("DeMeaning")
  nl_word  Nl[]      @relation("NlWord")
  nl_mean  Nl[]      @relation("NlMeaning")
  eo_word  Eo[]      @relation("EoWord")
  eo_mean  Eo[]      @relation("EoMeaning")

  @@map("meanings")
}

model Root {
  id    Int     @id @default(autoincrement())
  value String?
  type  Int?    @default(0)

  roots_words RootWord[]

  @@map("roots")
}

model Root_text {
  id      Int    @id
  value   String
  rootId  String

  @@ignore
}

model RootWord {
  id     Int  @id @default(autoincrement())
  wordId Int?
  rootId Int?

  word   Word? @relation(fields: [wordId], references: [id], onDelete: Cascade)
  root   Root? @relation(fields: [rootId], references: [id], onDelete: Cascade)

  @@map("roots_words")
}

model Synonym {
  id        Int    @id @default(autoincrement())
  rootId    Int?
  wordId    Int?
  proximity Float?

  root      Word?  @relation("SynonymRoot", fields: [rootId], references: [id], onDelete: Cascade)
  word      Word?  @relation("SynonymWord", fields: [wordId], references: [id], onDelete: Cascade)

  @@map("synonims")
}

model Antonym {
  id        Int    @id @default(autoincrement())
  rootId    Int?
  wordId    Int?
  proximity Float?

  root      Word?  @relation("AntonymRoot", fields: [rootId], references: [id], onDelete: Cascade)
  word      Word?  @relation("AntonymWord", fields: [wordId], references: [id], onDelete: Cascade)

  @@map("antonims")
}

// Динамические таблицы языков, преобразованные в схемы Prisma
