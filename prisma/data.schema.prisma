  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  value     String?
  veryfied  Int?
  wordId    Int?
  meaningId Int?

  word      Meaning? @relation("EnWord", fields: [wordId], references: [id], onDelete: Cascade)
  meaning   Meaning? @relation("EnMeaning", fields: [meaningId], references: [id], onDelete: Cascade)

  actionHistory String?

